{
  "respectGitignore": true,
  "permissions": {
    "allow": [
      "Bash(npm run build)",
      "Bash(npm run test *)",
      "Bash(npm view *)",
      "Bash(npm ls *)",
      "Bash(* --version)",
      "Bash(* --help)",
      "Bash(git status)",
      "Bash(git * log *)",
      "Bash(git * diff *)",
      "Bash(git * show *)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git show *)",
      "Bash(ls *)",
      "Bash(head *)",
      "Bash(cat *)",
      "Bash(grep *)",
      "Bash(rg *)",
      "Bash(wc *)",
      "Bash(find *)",
      "Bash(sed *)",
      "Back(mkdir *)",
      "Bash(flutter test*)",
      "Bash(uv sync*)",
      "Bash(uv run pytest*)",
      "Bash(uv run python -m pytest*)",
      "Bash(uv run behave*)",
      "Bash(uv run ruff check*)",
      "Bash(uv run ruff format*)",
      "Bash(uv run uvicorn*)",
      "Read(~/.local/**)",
      "Bash(gh pr list *)",
      "Bash(gh pr view *)",
      "Read(.)",
      "Search(.)",
      "Read(~/.zprofile)",
      "Bash(uvx tox:*)",
      "Read(~/.zshrc)",
      "Bash(bats *)",
      "Bash(launchctl list *)",
      "Bash(python3 -m pytest tests/ *)",
      "Bash(uvx pytest*)",
      "Bash(npx jest*)",
      "Read(~/.claude/**)",
      "Search(~/.claude/**)",
      "Write(~/.claude/cost-log/**)",
      "Write(~/.claude/extract_cost.py)",
      "Write(~/.claude/COST-SUMMARY.md)",
      "Bash(cat ~/.claude/cost-log/*)",
      "Bash(brew list:*)",
      "Bash(command -v trash)",
      "WebFetch(domain:developers.dropbox.com)",
      "Bash(npm install:*)",
      "Bash(npx vitest:*)",
      "WebFetch(domain:dropbox.github.io)",
      "Bash(npm test:*)",
      "Bash(~/.claude/plugins/cache/claude-plugins-official/superpowers/5.0.6/skills/brainstorming/scripts/start-server.sh *)"
    ],
    "deny": [
      "Bash(*gh pr create*)",
      "Bash(*gh pr merge*)",
      "Bash(*gh pr close*)",
      "Bash(*gh pr edit*)",
      "Bash(*gh pr comment*)",
      "Bash(*gh pr review*)",
      "Bash(*gh pr ready*)",
      "Bash(*gh pr reopen*)",
      "Bash(*gh issue create*)",
      "Bash(*gh issue close*)",
      "Bash(*gh issue edit*)",
      "Bash(*gh issue comment*)",
      "Bash(*gh issue delete*)",
      "Bash(gh issue reopen*)",
      "Bash(gh issue transfer*)",
      "Bash(gh release create*)",
      "Bash(gh release delete*)",
      "Bash(gh release edit*)",
      "Bash(gh repo create*)",
      "Bash(gh repo delete*)",
      "Bash(gh repo edit*)",
      "Bash(gh repo archive*)",
      "Bash(gh repo fork*)",
      "Bash(gh repo rename*)",
      "Bash(gh gist create*)",
      "Bash(gh gist edit*)",
      "Bash(gh gist delete*)",
      "Bash(gh label create*)",
      "Bash(gh label edit*)",
      "Bash(gh label delete*)",
      "Bash(gh run cancel*)",
      "Bash(gh run rerun*)",
      "Bash(gh workflow run*)",
      "Bash(gh api *-X POST*)",
      "Bash(gh api *-X PUT*)",
      "Bash(gh api *-X PATCH*)",
      "Bash(gh api *-X DELETE*)",
      "Bash(gh api *-f body=*)",
      "Bash(gh api *-f *=*)",
      "Bash(gh api graphql*-f query=*mutation*)",
      "Bash(gh api *--method POST*)",
      "Bash(gh api *--method PUT*)",
      "Bash(gh api *--method PATCH*)",
      "Bash(gh api *--method DELETE*)"
    ],
    "ask": [
      "Bash(*git commit *)",
      "Write(*settings.json*)",
      "Delete(*settings.json*)",
      "Update(*settings.json*)",
      "Bash(*settings.json*)",
      "Write(.)",
      "Bash(gh api*)",
      "Bash(find*-delete*)",
      "Bash(find*-exec*)",
      "Bash(sed*-i*)"
    ],
    "defaultMode": "default"
  },
  "model": "opus[1m]",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/block-inline-scripts.py",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "swift-lsp@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "figma@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "agent-sdk-dev@claude-plugins-official": true,
    "playground@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "hookify@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true,
    "csharp-lsp@claude-plugins-official": true,
    "stripe@claude-plugins-official": true,
    "sentry@claude-plugins-official": true,
    "jdtls-lsp@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "firebase@claude-plugins-official": true,
    "chrome-devtools-mcp@claude-plugins-official": true,
    "kotlin-lsp@claude-plugins-official": true,
    "ruby-lsp@claude-plugins-official": true,
    "lua-lsp@claude-plugins-official": true,
    "clangd-lsp@claude-plugins-official": true,
    "plugin-dev@claude-plugins-official": true,
    "huggingface-skills@claude-plugins-official": true,
    "microsoft-docs@claude-plugins-official": true,
    "firecrawl@claude-plugins-official": true
  },
  "fastMode": false,
  "prefersReducedMotion": true,
  "themePreference": "light"
}
