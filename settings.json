{
  "respectGitignore": true,
  "permissions": {
    "allow": [
      "Bash(npm run build)",
      "Bash(npm run test *)",
      "Bash(npm view *)",
      "Bash(npm ls *)",
      "Bash(* --version)",
      "Bash(* --help)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git diff * \"---UNSTAGED---\" *)",
      "Bash(git -C * diff *)",
      "Bash(git log*)",
      "Bash(git show *)",
      "Bash(gh api *)",
      "Bash(ls *)",
      "Bash(head *)",
      "Bash(cat *)",
      "Bash(grep *)",
      "Bash(rg *)",
      "Bash(wc *)",
      "Bash(find *)",
      "Bash(sed *)",
      "Back(mkdir *)",
      "Bash(flutter test*)",
      "Bash(uv sync*)",
      "Bash(uv run pytest*)",
      "Bash(uv run python -m pytest*)",
      "Bash(uv run behave*)",
      "Bash(uv run ruff check*)",
      "Bash(uv run ruff format*)",
      "Bash(uv run uvicorn*)",
      "Read(~/.local/**)",
      "Bash(python3 ~/.claude/extract_cost.py *)",
      "Read(~/.claude/extract_cost.py)",
      "Search(~/.claude/extract_cost.py)",
      "Bash(gh pr list *)",
      "Bash(gh pr view *)",
      "Read(.)",
      "Search(.)",
      "Read(~/.claude/**)",
      "Write(~/.claude/cost-log/**)",
      "Search(~/.claude/**)",
      "Read(~/.zprofile)",
      "Bash(uvx tox:*)",
      "Read(~/.zshrc)",
      "Bash(bats *)"
    ],
    "ask": [
      "Bash(python*)",
      "Bash(gh api*-X*)",
      "Bash(gh api graphql*)",
      "Bash(find*-delete*)",
      "Bash(find*-exec*)",
      "Bash(sed*-i*)",
      "Read(//**)",
      "Search(//**)",
      "Write(//**)"
    ],
    "defaultMode": "default"
  },
  "model": "opus[1m]",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/block-inline-scripts.py",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
  },
  "fastMode": false,
  "prefersReducedMotion": true,
  "themePreference": "light"
}
